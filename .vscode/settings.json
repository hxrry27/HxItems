{
  // Java source paths
  "java.project.sourcePaths": [
    "src/main/java"
  ],
  "java.project.outputPath": "target/classes",
  "java.project.resourceFilters": [
    "node_modules",
    ".git"
  ],
  
  // Auto-update Maven configuration
  "java.configuration.updateBuildConfiguration": "automatic",
  
  // Maven settings
  "maven.terminal.useJavaHome": true,
  "maven.executable.path": "mvn",
  
  // Java compiler settings
  "java.compile.nullAnalysis.mode": "automatic",
  "java.configuration.runtimes": [
    // Uncomment and adjust if you want to specify Java version
    // {
    //   "name": "JavaSE-21",
    //   "path": "/path/to/jdk-21"
    // }
  ],
  
  // Code formatting (optional but recommended)
  "java.format.settings.url": null,
  "java.format.settings.profile": "GoogleStyle",
  "java.format.enabled": true,
  
  // Auto-save (helpful for Maven projects)
  "files.autoSave": "onFocusChange",
  
  // Exclude build artifacts from file explorer
  "files.exclude": {
    "**/.git": true,
    "**/.settings": true,
    "**/.factorypath": true
  },
  
  // File associations
  "files.associations": {
    "*.yml": "yaml",
    "pom.xml": "xml"
  },
  
  // Editor settings for Java
  "[java]": {
    "editor.defaultFormatter": "redhat.java",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true
  },
  
  // YAML formatting (for plugin.yml and config.yml)
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true
  }
}